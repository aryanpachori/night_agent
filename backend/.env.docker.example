# Copy to backend/.env for Docker runs and fill secrets.

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
JUPITER_API_KEY=your_jupiter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NEWS_API_KEY=your_news_api_key_here
OPENAI_API_KEY=

# API
JWT_SECRET=replace_with_at_least_16_chars
API_PORT=4000
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Postgres (used by backend/docker-compose.yml)
POSTGRES_DB=night_agent
POSTGRES_USER=nightagent
POSTGRES_PASSWORD=nightagent
POSTGRES_PORT=5432

# Prisma/Backend DB URL (container-to-container host is "db")
DATABASE_URL=postgresql://nightagent:nightagent@db:5432/night_agent
