# ─── Telegram ─────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow steps → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 2. Start your bot, then message @userinfobot on Telegram → copy your ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Jupiter Prediction Market API ───────────────────────────────────────────
# Get free key at: https://developers.jup.ag/portal → Create API Key
JUPITER_API_KEY=your_jupiter_api_key_here

# ─── LLM (use at least one) ───────────────────────────────────────────────────
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Gemini models: the bot uses RPD–aware rotation by default (3.1 Flash Lite primary → 2.5 Flash for
# high–volume markets → 2.0 Flash → 2.5 Flash Lite → Gemma 3 27B). Counters reset at local midnight;
# with DATABASE_URL they persist across restarts.
# Set this ONLY to pin one model and disable rotation (debug / paid tier):
# GEMINI_MODEL=gemini-2.5-flash
# “Premium” 2.5 Flash is used when market volume (USD) is at/above this (default 100_000):
# GEMINI_PREMIUM_MIN_VOLUME=100000
# Min ms between Gemini requests (default 13000). Lower only if you have paid quota.
GEMINI_MIN_INTERVAL_MS=13000
# Retries when Google returns 429 / RESOURCE_EXHAUSTED (default 3).
GEMINI_MAX_RETRIES=3
# Reuse LLM output per market to save daily quota (default 90 minutes).
LLM_CACHE_TTL_MINUTES=90
# If Gemini fails and OPENAI_API_KEY is unset: use math+crowd fallback (default on). Set 0 to throw instead.
# LLM_MATH_ONLY_FALLBACK=0
# When chatting "what do you think my win percent is?" on an open bet, call Gemini (default on). Set 0 for snapshot-only.
# CHAT_POSITION_LLM=1
# Optional fallback: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── News ─────────────────────────────────────────────────────────────────────
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ─── PostgreSQL (optional) — persists wallet, price history, LLM cache across restarts
# Leave unset to use in-memory only (resets on restart). After set: npx prisma generate && npx prisma db push
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/night_action

# ─── Paper trading config ─────────────────────────────────────────────────────
PAPER_BALANCE=1000
SCAN_INTERVAL_MINUTES=5
# New-listing scan interval (was every 1 min; default 5 min is gentler on Gemini free tier RPD).
NEW_MARKET_SCAN_MINUTES=5
MONITOR_INTERVAL_MINUTES=10
# Open position PnL “heartbeat” on Telegram (move vs last tick + cooldown)
PRICE_TICK_MIN_MOVE=0.04
PRICE_TICK_INTERVAL_MINUTES=12
# Show “Exit full / half” on /positions, /status, price ticks when |unrealized| ≥ this (USD). Default 0.01.
# MANUAL_EXIT_MIN_UNREALIZED=0.01
# Stop\\-loss in monitor: auto\\-exits, then Telegram notifies. Take\\-profit/edge: manual EXIT \\| HALF \\| HOLD only.
# Cent move on your side (default 12 if unset). Example: 15 = exit when the outcome price falls 15¢ from entry.
# STOP_LOSS_CENTS=12
# Or exit by stake: close when *mark value* (contracts × mark price) is at or below this % of cost.
# 50 = if you risked $100, exit when mark ≤ $50 (50% of cost lost in MTM). Runs every tick; no 5¢ gate.
# STOP_LOSS_DRAWDOWN_PCT=50

# ─── Market filters ───────────────────────────────────────────────────────────
# /scan and /markets use Jupiter /events — default live only (omit new and trending)
# Set e.g. live,new or live,trending if you want first-mover or high-activity too.
# SCAN_JUPITER_FILTERS=live
MIN_VOLUME=0                                   # paper trading — trade all markets
MIN_EDGE=0.08                                  # 8% min edge (covers Jupiter fees)
MIN_PRICE=0.10                                 # skip markets below 10c
MAX_PRICE=0.90                                 # skip markets above 90c
# No minimum day-by-default; 5m/1h/daily markets can qualify. Tighten with:
# MIN_HOURS_LEFT=24   (≈1 day min until close)   MIN_RESOLVE_MINUTES=0
# Skip opportunities on markets that resolve in less than this (seconds). Cuts “3 min left” coin-flip noise.
# Example: 3600 = 1 hour minimum. Leave unset for no gate on time-to-resolve.
# MIN_RESOLVE_SECONDS=3600
# Or: MIN_HOURS_TO_RESOLVE=1
MAX_DAYS_LEFT=365
MAX_BET_PERCENT=0.10
# Hard cap on Kelly-sized stake (after MAX_BET_PERCENT). Example: 50 keeps single bets from blowing up on 20% bankroll Kelly.
# MAX_BET_USD=50
TA_REQUIRED=false                              # set true to skip markets with no TA signal

# ─── Bot limits ───────────────────────────────────────────────────────────────
# Focus: pending opportunity alerts + open bets; when sum ≥ cap, scanning sends nothing.
MAX_FOCUS_EVENTS=2
# Max *new* opportunity *Telegram alerts* per full rolling hour (0 = no hourly limit)
MAX_OPPORTUNITY_ALERTS_PER_HOUR=2
# Per scan, max alerts this run (default 1 — avoids 3+ BETs in one minute)
MAX_OPPORTUNITIES_PER_SCAN=1
MORE_OPPORTUNITIES_COUNT=2
MAX_OPEN_POSITIONS=2
MIN_BANKROLL=10
