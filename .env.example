# ─── Telegram ─────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow steps → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 2. Start your bot, then message @userinfobot on Telegram → copy your ID
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Jupiter Prediction Market API ───────────────────────────────────────────
# Get free key at: https://developers.jup.ag/portal → Create API Key
JUPITER_API_KEY=your_jupiter_api_key_here

# ─── LLM (use at least one) ───────────────────────────────────────────────────
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# Optional fallback: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── News ─────────────────────────────────────────────────────────────────────
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ─── Paper trading config ─────────────────────────────────────────────────────
PAPER_BALANCE=1000
SCAN_INTERVAL_MINUTES=5
MONITOR_INTERVAL_MINUTES=30

# ─── Market filters ───────────────────────────────────────────────────────────
MIN_VOLUME=0                                   # paper trading — trade all markets
MIN_EDGE=0.08                                  # 8% min edge (covers Jupiter fees)
MIN_PRICE=0.10                                 # skip markets below 10c
MAX_PRICE=0.90                                 # skip markets above 90c
MIN_DAYS_LEFT=1
MAX_DAYS_LEFT=365
MAX_BET_PERCENT=0.10
TA_REQUIRED=false                              # set true to skip markets with no TA signal

# ─── Bot limits ───────────────────────────────────────────────────────────────
MAX_OPEN_POSITIONS=10                          # paper trading — allow more positions
MIN_BANKROLL=10
