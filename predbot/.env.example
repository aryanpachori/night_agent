# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Jupiter Prediction Market API ───────────────────────────────────────────
# Get your key at: https://portal.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ─── LLM (use at least one) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here        # optional fallback

# ─── News ─────────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here             # newsapi.org free tier

# ─── Paper trading config ─────────────────────────────────────────────────────
PAPER_BALANCE=1000                             # starting USDC balance
SCAN_INTERVAL_MINUTES=5                        # how often to scan markets
MONITOR_INTERVAL_MINUTES=30                    # how often to check positions

# ─── Market filters ───────────────────────────────────────────────────────────
MIN_VOLUME=1000000                             # minimum market volume $1 (in native units: 1000000 = $1)
MIN_EDGE=0.05                                  # minimum 5% edge to bet
MIN_PRICE=0.15                                 # skip markets below 15c
MAX_PRICE=0.85                                 # skip markets above 85c
MIN_DAYS_LEFT=7                                # skip markets expiring < 7 days
MAX_DAYS_LEFT=90                               # skip markets expiring > 90 days
MAX_BET_PERCENT=0.10                           # max 10% of bankroll per bet

# ─── Bot limits ───────────────────────────────────────────────────────────────
MAX_OPEN_POSITIONS=5                           # max concurrent open bets
MIN_BANKROLL=50                                # stop scanning if balance < $50
